// Exercício 03
import java.util.Scanner;

public class Ex03{
	public static void main(String[] args) {
	
		Scanner leitor = new Scanner(System.in);
	    
	    System.out.println("Qual o raio da base? ");
	    double raio = leitor.nextDouble();
	    
	    System.out.println("Qual o valor da altura em metros? ");
	    float altura = leitor.nextFloat();
	    
	    double volume = Math.PI * Math.pow(raio, 2) * altura;
	    
	    System.out.println("O volume = " + volume + " m³");
	
	}
}

// Exercício 04
import java.util.Scanner;

public class Ex04{
	public static void main(String[] args) {
	
		Scanner leitor = new Scanner(System.in);
	    
	    System.out.println("Qual a potencia do equipamento em watts? ");
	    double potencia = leitor.nextDouble();
	    
	    System.out.println("Por quantas horas fica ligado? ");
	    float tempo = leitor.nextFloat();
	   
	    System.out.println("Qual o preço do KWh? ");
	    double precoConsumoDeEnergia = leitor.nextDouble(); 
	    
	    //calculo de KWh/mes
	    double consumoEnergetico = (potencia * tempo * 30) / 1000;
	    double consumoFinal = consumoEnergetico * precoConsumoDeEnergia;
	    
	    System.out.println("Consumo energéico por mês: " + consumoEnergetico);
	    System.out.println("Consumo final por mês: " + consumoFinal);
	
	}
}

// Exercício 05
import java.util.Scanner;

public class Ex05{
	public static void main(String[] args) {
	
		Scanner leitor = new Scanner(System.in);
	    
	    // calculo da area 
	    System.out.println("Qual o raio da praça? ");
	    double raio = leitor.nextDouble();
	    double areaDaPraca = Math.PI * Math.pow(raio, 2);
	    
	    //calculo do custo
	    System.out.println("Qual o valor do metro quadrado do piso? ");
	    double valorDoMetro = leitor.nextDouble();
	    double custoDoMaterial = areaDaPraca * valorDoMetro;
	    
	    System.out.println("A área da praça: " + areaDaPraca + " Custo do material: R$ " + custoDoMaterial);
	    
	    
	}
}

