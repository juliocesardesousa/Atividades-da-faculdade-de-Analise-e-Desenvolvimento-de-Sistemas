// Exercício 01
import java.util.Scanner;

public class Ex01{
	public static void main(String[] args) {
		
		Scanner leitor = new Scanner(System.in);
	    
	    System.out.println("Coloque o valor da distância percorrida em Km");
	    double distanciaPercorrida = leitor.nextDouble();
	    
	    System.out.println("Coloque o valor do tempo gasto em horas");
	    double tempoGasto = leitor.nextDouble();
	    
	    double velocidadeMedia = distanciaPercorrida / tempoGasto;
	    
	    System.out.println("Velocidade média: " + velocidadeMedia + " Km/h");
	
	}
}

