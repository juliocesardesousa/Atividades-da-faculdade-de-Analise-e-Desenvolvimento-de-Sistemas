import java.util.Scanner;

public class Ex{
    public static void main (String [] args){
        
        Scanner scanner =  new Scanner (System.in);
            
         System.out.println("Qual o seu ano de nascimento? ");
         int anoNascimento = scanner.nextInt();
         
         System.out.println("Em que ano nós estamos? ");
         int ano = scanner.nextInt();
         
         int idade = ano - anoNascimento;
        
        if ( idade >= 16 && idade < 18)
        {
            System.out.println("Você tem idade para votar, mas não pode tirar a CNH");
        }
        
        if ( idade >= 18)
        {
            System.out.println("Você tem idade para votar e pode tirar a CNH");
        }
        
        else
            System.out.println("Você ainda não tem 16 anos ");

    }

}    

