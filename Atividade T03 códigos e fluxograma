// Exercicio 05: Calculo do IMC
import java.util.Scanner;

public class Ex05{
    public static void main (String [] args){
        
        Scanner scanner = new Scanner (System.in);
        
        System.out.println("Qual o seu peso? ");
        double peso = scanner.nextDouble();
        
        System.out.println("Qual a sua altura? ");
        double altura = scanner.nextDouble();
        
        double imc = peso / Math.pow(altura, 2);
        
        System.out.printf("O seu índice de massa corporal (IMC) é de: %.3f%n", imc);
        scanner.close();
        
    }
}

// Exercicio 06: Transformação de base de tempo
import java.util.Scanner;

public class Ex06
{
	public static void main(String[] args) {
		
		Scanner scanner =  new Scanner (System.in);
		
		System.out.println("Qual o valor em segundos a ser transformado? ");
		double valorTrasnformar = scanner.nextDouble();
		
		//fórmula para pegar somente o decimal do valor (valor a Trasnformar % valor de conversão) / valor de conversão
		double horasDecimal = (valorTrasnformar % 3600) / 3600;
		double horas = (valorTrasnformar / 3600) - horasDecimal;
		
		//pego o decimal dos minutos, pois | valorTrasnformar/60 tem o mesmo decimal que (valorTrasnformar/3600) - o inteiro da divisão |  
		double minutosDecimal = (valorTrasnformar % 60 ) / 60;
		double minutos = (horasDecimal * 60) - minutosDecimal;
		
		//pega o valor e tira o decimal e arredonda para o inteior mais proximo
		double segundos = (minutosDecimal * 60) % 60;
		
		System.out.println("O valor: " + valorTrasnformar + " equivale a: ");
		
		//%s mostra a string na tela, \n coloca o cursor na outra linha, %f coloco o ponto flutuante 
		System.out.printf("%.0f%s\n", horas, " h" );
		System.out.printf("%.0f%s\n", minutos, " min");
		System.out.printf("%.0f%s\n", segundos, " s" );
		scanner.close();
	}
}


